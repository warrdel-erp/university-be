{
  "name": "university_erp",
  "version": "1.0.0",
  "description": "",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "nodemon server.js",
    "docker:build": "docker build -t univ-be .",
    "docker:run": "docker run -td --name univ-be --env-file .env -p 6002:6002 --restart on-failure:5 univ-be ",
    "migrate": "npx sequelize-cli db:migrate --env development",
    "migrate:status": "npx sequelize-cli db:migrate:status --env development",
    "migrate:undo": "npx sequelize-cli db:migrate:undo --env development",
    "migrate:undo:all": "npx sequelize-cli db:migrate:undo:all --env development",
    "seed": "npx sequelize-cli db:seed:all --env development",
    "seed:undo": "npx sequelize-cli db:seed:undo:all --env development",
    "server": "nodemon deplay--500ms server.js"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "nodemon": "^3.0.1",
    "sequelize-cli": "^6.6.3"
  },
  "dependencies": {
    "aws-sdk": "^2.1658.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "csv-parser": "^3.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-fileupload": "^1.5.0",
    "form-data": "^4.0.0",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.30.1",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "mysql2": "^3.10.2",
    "nodemailer": "^7.0.6",
    "sequelize": "^6.37.3",
    "uuid": "^10.0.0",
    "xlsx": "^0.18.5"
  }
}
